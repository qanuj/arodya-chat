# ── Zernio ────────────────────────────────────────────────────────────────────
# Get these from: https://zernio.com/dashboard → Settings → API
ZERNIO_API_KEY=your_zernio_api_key_here
ZERNIO_WEBHOOK_SECRET=5nuhAFQGcHPkHKR

# Optional — override if self-hosting Zernio
# ZERNIO_API_BASE_URL=https://zernio.com/api

# Optional — display name shown in Zernio dashboard
ZERNIO_BOT_NAME=Arodya

# ── Redis (production state) ──────────────────────────────────────────────────
# Required in production. Omit in local dev to fall back to in-memory state.
# Vercel KV: Settings → Storage → KV → Connect → copy REDIS_URL
REDIS_URL=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
